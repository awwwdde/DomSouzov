{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "backend",
      "runtimeExecutable": "backend\\venv\\Scripts\\python.exe",
      "runtimeArgs": ["-m", "uvicorn", "backend.main:app", "--reload", "--port", "8001"],
      "port": 8001
    },
    {
      "name": "prodlike",
      "runtimeExecutable": "backend\\venv\\Scripts\\python.exe",
      "runtimeArgs": ["-m", "uvicorn", "backend.main:app", "--port", "8002", "--no-server-header"],
      "port": 8002,
      "env": { "STATIC_DIR": "frontend/dist" }
    }
  ]
}
