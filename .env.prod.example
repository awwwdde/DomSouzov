# Скопируйте в .env рядом с docker-compose.prod.yml и заполните значения.
#   cp .env.prod.example .env && nano .env

# --- База данных (Postgres внутри docker-compose) ---
DB_USER=domuser
DB_NAME=domsoyuzov
# Придумайте надёжный пароль (можно: openssl rand -hex 16):
DB_PASSWORD=ЗАМЕНИТЬ_надёжный_пароль_БД

# --- Безопасность приложения ---
# 32+ случайных символа. Сгенерировать: openssl rand -hex 32
SECRET_KEY=ЗАМЕНИТЬ_32+_случайных_символа

# Сколько доверенных обратных прокси стоит перед приложением.
# В docker-compose.prod.yml это ровно один caddy, поэтому 1.
# 0 сломает rate-limit: все посетители будут выглядеть как один IP.
TRUSTED_PROXY_COUNT=1

# --- Домен (canonical/og/sitemap строятся отсюда) ---
SITE_URL=https://domsojuzov.ru
CORS_ORIGINS=https://domsojuzov.ru

# --- Логин администратора (создаётся при старте; при наличии — сбрасывается под эти значения) ---
ADMIN_EMAIL=admin@domsojuzov.ru
ADMIN_PASSWORD=ЗАМЕНИТЬ_надёжный_пароль_админа

# --- SMTP для писем-заявок «Организаторам» (необязательно) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
