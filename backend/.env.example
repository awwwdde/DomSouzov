# =============================================================================
# Дом Союзов — переменные окружения.
#
# НА ПРОДЕ (awwwdde-panel) НИЧЕГО ЗДЕСЬ НЕ НУЖНО руками для БД/секретов:
#   • DATABASE_URL  — панель сама создаёт гостю Postgres и прокидывает URL.
#   • SECRET_KEY / JWT_SECRET — панель генерирует и прокидывает (стабильны
#     между деплоями). Данные переживают обновления GitHub.
#   • Админ — задайте в UI панели пресет «Bootstrap-админ» → создаст
#     BOOTSTRAP_ADMIN_EMAIL и BOOTSTRAP_ADMIN_PASSWORD (env проекта).
#     При деплое админ создаётся; если уже есть — пароль сбрасывается под env.
#
# Этот файл нужен в основном для ЛОКАЛЬНОЙ разработки.
# =============================================================================

# Локальный быстрый старт (без PostgreSQL):
DATABASE_URL=sqlite:///./domsoyuzov.db
# PostgreSQL (как на проде):
# DATABASE_URL=postgresql+psycopg2://user:PASSWORD@host:5432/dbname

# Секрет подписи JWT. На проде прокидывает панель; локально задайте свой.
SECRET_KEY=change-me-in-production-use-32-random-chars

# ── Админ ──
# Прод: BOOTSTRAP_ADMIN_* задаёт панель. Локально достаточно ADMIN_*.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
ADMIN_EMAIL=admin@dom-soyuzov.ru
# Пустой пароль = админ НЕ создаётся (чтобы не было дефолтного небезопасного).
# Для локального входа задайте свой:
ADMIN_PASSWORD=

# Демо-контент (события/новости/залы/галерея) при ПУСТОЙ БД.
# На проде поставьте false для чистого старта.
SEED_DEMO_CONTENT=true

UPLOAD_DIR=uploads

# Публичный домен (через запятую можно несколько):
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://union.awwwdde.art
SITE_URL=https://union.awwwdde.art

# ── SMTP: отправка заявок с формы «Организаторам» ──
# Если SMTP_HOST пуст — письма не шлются, но заявки сохраняются в БД и видны
# в админке. Получатель письма настраивается в админке (Организаторам →
# «Email для заявок»); SMTP_TO — запасной получатель.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
